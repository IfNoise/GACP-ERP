{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "../../dist/apps/quality-service",
    "baseUrl": "../..",
    "incremental": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*"]
}

{
  "name": "web-portal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web-portal",
  "projectType": "application",
  "tags": ["type:app", "runtime:nextjs", "scope:web", "compliance:high"],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/web-portal"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "web-portal:build",
        "dev": true,
        "port": 3000
      },
      "configurations": {
        "development": { "buildTarget": "web-portal:build:development", "dev": true },
        "production": { "buildTarget": "web-portal:build:production", "dev": false }
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "apps/web-portal"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": { "lintFilePatterns": ["apps/web-portal/**/*.{ts,tsx}"] }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/web-portal"],
      "options": { "jestConfig": "apps/web-portal/jest.config.ts" }
    }
  }
}

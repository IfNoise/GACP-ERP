# Validate commit message format (conventional commits)
# Runs with the commit message file as $1 — correct place for this check
COMMIT_MSG=$(head -1 "$1")
PATTERN="^(feat|fix|docs|test|refactor|compliance|chore|perf|ci|build|revert)(\([a-z0-9/._-]+\))?: .{1,100}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "❌ Commit message does not match the required format."
  echo "   Required: <type>(<scope>): <subject>"
  echo "   Types: feat | fix | docs | test | refactor | compliance | chore | perf | ci | build | revert"
  echo "   Example: feat(cultivation): add plant lifecycle state machine"
  echo ""
  echo "   Got: $COMMIT_MSG"
  exit 1
fi

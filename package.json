{
  "name": "gacp-erp",
  "version": "1.0.0",
  "private": true,
  "description": "GACP-ERP — GMP/GACP-compliant cultivation management system",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "nx run-many --target=lint --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "test": "nx run-many --target=test --all",
    "build": "nx run-many --target=build --all --configuration=production",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml}\" --ignore-path .prettierignore",
    "affected:lint": "nx affected --target=lint",
    "affected:typecheck": "nx affected --target=typecheck",
    "affected:test": "nx affected --target=test",
    "affected:build": "nx affected --target=build",
    "graph": "nx graph",
    "reset": "nx reset",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "infra:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "infra:dev": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml up -d",
    "openapi:generate": "tsx libs/shared/contracts/src/openapi.ts"
  },
  "devDependencies": {
    "@nx-go/nx-go": "~2.2.0",
    "@nx/esbuild": "~20.4.0",
    "@nx/eslint": "~20.4.0",
    "@nx/eslint-plugin": "~20.4.6",
    "@nx/jest": "~20.4.0",
    "@nx/js": "~20.4.0",
    "@nx/nest": "~20.4.0",
    "@nx/next": "~20.4.0",
    "@nx/node": "~20.4.0",
    "@nx/react": "~20.4.0",
    "@nx/webpack": "~20.4.0",
    "@playwright/test": "^1.58.2",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "~29.5.14",
    "@types/node": "~22.10.0",
    "@typescript-eslint/eslint-plugin": "~8.18.0",
    "@typescript-eslint/parser": "~8.18.0",
    "@typescript-eslint/utils": "~8.18.0",
    "eslint": "~9.17.0",
    "eslint-plugin-import": "~2.31.0",
    "husky": "~9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "~15.4.3",
    "nx": "~20.4.0",
    "prettier": "~3.4.2",
    "ts-jest": "~29.2.5",
    "ts-node": "~10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "~2.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@ts-rest/open-api": "^3.52.1",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "@xeokit/xeokit-sdk": "^2.6.107",
    "prom-client": "^15.1.3",
    "recharts": "^2.15.4"
  }
}

{
  "$schema": "https://json-schema.org/schema",
  "cli": "nx",
  "id": "library",
  "title": "GACP-ERP Library Generator",
  "description": "Creates a shared library with Zod-First patterns",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Library name (kebab-case)",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What is the library name?"
    },
    "directory": {
      "type": "string",
      "description": "Directory relative to libs/ (e.g. shared)",
      "default": ""
    },
    "type": {
      "type": "string",
      "description": "Library type",
      "enum": ["data-access", "ui", "business-logic", "utility"],
      "default": "utility",
      "x-prompt": {
        "message": "What type of library?",
        "type": "list",
        "items": [
          { "value": "data-access", "label": "Data Access (DB, API calls)" },
          { "value": "ui", "label": "UI Components (React)" },
          { "value": "business-logic", "label": "Business Logic (domain, use-cases)" },
          { "value": "utility", "label": "Utility (helpers, schemas, contracts)" }
        ]
      }
    },
    "tags": {
      "type": "string",
      "description": "Comma-separated tags for NX boundary enforcement",
      "default": ""
    },
    "withTests": {
      "type": "boolean",
      "description": "Generate test scaffolding",
      "default": true
    }
  },
  "required": ["name"]
}

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=gacp
POSTGRES_PASSWORD=gacp_secret_2026
POSTGRES_DB=gacp_erp
DATABASE_URL=postgresql://gacp:gacp_secret_2026@localhost:5432/gacp_erp

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2026
REDIS_URL=redis://:redis_secret_2026@localhost:6379

# ─── Kafka ────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9093
KAFKA_CLIENT_ID=gacp-erp
KAFKA_GROUP_ID=gacp-consumer-group

# ─── Keycloak ─────────────────────────────────────────────────────
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret_2026
KEYCLOAK_REALM=gacp-erp
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/gacp-erp
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/gacp-erp/protocol/openid-connect/certs
KEYCLOAK_CLIENT_API_GATEWAY=api-gateway
KEYCLOAK_CLIENT_API_GATEWAY_SECRET=api-gateway-secret-change-in-prod
KEYCLOAK_CLIENT_WEB_PORTAL=web-portal

# ─── ImmuDB ───────────────────────────────────────────────────────
IMMUDB_HOST=localhost
IMMUDB_PORT=3322
IMMUDB_ADMIN_PASSWORD=immudb_secret_2026
IMMUDB_USER=immudb
IMMUDB_PASSWORD=immudb_secret_2026
IMMUDB_DATABASE=gacp_audit

# ─── MongoDB ──────────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=gacp
MONGO_PASSWORD=mongo_secret_2026
MONGO_DB=gacp_erp
MONGO_URL=mongodb://gacp:mongo_secret_2026@localhost:27017/gacp_erp?authSource=admin

# ─── VictoriaMetrics ──────────────────────────────────────────────
VM_HOST=localhost
VM_PORT=8428
VM_URL=http://localhost:8428

# ─── Application ──────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_PREFIX=api
API_VERSION=v1

# ─── Security ─────────────────────────────────────────────────────
JWT_SECRET=change-this-jwt-secret-in-production-must-be-at-least-32-chars
QR_HMAC_SECRET=change-this-qr-hmac-secret-in-production
ELECTRONIC_SIGNATURE_RSA_PRIVATE_KEY_PATH=./certs/private.pem
ELECTRONIC_SIGNATURE_RSA_PUBLIC_KEY_PATH=./certs/public.pem

# ─── Dev Tools ────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@gacp-erp.local
PGADMIN_PASSWORD=pgadmin_dev_2026

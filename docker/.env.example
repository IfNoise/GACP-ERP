# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=gacp
POSTGRES_PASSWORD=gacp_secret_2026
POSTGRES_DB=gacp_erp
DATABASE_URL=postgresql://gacp:gacp_secret_2026@localhost:5432/gacp_erp

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2026
REDIS_URL=redis://:redis_secret_2026@localhost:6379

# ─── Kafka ────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9094
KAFKA_CLIENT_ID=gacp-erp
KAFKA_GROUP_ID=gacp-consumer-group

# ─── Zitadel (Identity Provider) ──────────────────────────────
ZITADEL_PORT=8080
ZITADEL_DOMAIN=localhost:8080
ZITADEL_URL=http://localhost:8080
ZITADEL_ISSUER=http://localhost:8080
ZITADEL_JWKS_URI=http://localhost:8080/oauth/v2/certs
# ZITADEL_MASTERKEY: 32-byte base64-encoded key (generate with: openssl rand -base64 32)
ZITADEL_MASTERKEY=change-this-to-32-byte-base64-key-in-production-xxxxxxxxxxxxx
ZITADEL_ORG_NAME=GACP-ERP
# Run `pnpm tsx scripts/setup-zitadel.mts` to get the values below:
ZITADEL_PROJECT_ID=change-in-production
# web-portal SPA (public client — PKCE only, no secret)
ZITADEL_CLIENT_ID=change-in-production
ZITADEL_CLIENT_SECRET=
# api-gateway confidential client (password grant + client_credentials)
ZITADEL_API_GW_CLIENT_ID=change-in-production
ZITADEL_API_GW_CLIENT_SECRET=change-in-production
# admin-service machine user PAT (for workforce-service user provisioning)
ZITADEL_ADMIN_CLIENT_ID=admin-service
ZITADEL_ADMIN_PAT=change-in-production

# ─── ImmuDB ───────────────────────────────────────────────────────
IMMUDB_HOST=localhost
IMMUDB_PORT=3322
IMMUDB_ADMIN_PASSWORD=Immudb@2026!
IMMUDB_USER=immudb
IMMUDB_PASSWORD=Immudb@2026!
IMMUDB_DATABASE=gacp_audit

# ─── MongoDB ──────────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=gacp
MONGO_PASSWORD=mongo_secret_2026
MONGO_DB=gacp_erp
MONGO_URL=mongodb://gacp:mongo_secret_2026@localhost:27017/gacp_erp?authSource=admin

# ─── VictoriaMetrics ──────────────────────────────────────────────
VM_HOST=localhost
VM_PORT=8428
VM_URL=http://localhost:8428

# ─── Application ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
API_PORT=3000
API_PREFIX=api
API_VERSION=v1
WEB_PORTAL_URL=http://localhost:3000
API_GATEWAY_PORT=3001

# ─── Security ─────────────────────────────────────────────────────
JWT_SECRET=change-this-jwt-secret-in-production-must-be-at-least-32-chars
# AUTH_SECRET: used by next-auth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=change-this-nextauth-secret-min-32-chars-xxxxxxxx
# HMAC_SECRET: used by api-gateway for internal message signing (min 32 chars)
HMAC_SECRET=change-this-hmac-secret-min-32-chars-xxxxxxxxx
QR_HMAC_SECRET=change-this-qr-hmac-secret-in-production
# REAUTH_SECRET: used by api-gateway for 21 CFR §11.200 re-auth tokens (min 32 chars)
# Generate with: openssl rand -base64 32
REAUTH_SECRET=change-this-reauth-secret-min-32-chars-xxxxxxxxx
ELECTRONIC_SIGNATURE_RSA_PRIVATE_KEY_PATH=./certs/private.pem
ELECTRONIC_SIGNATURE_RSA_PUBLIC_KEY_PATH=./certs/public.pem
# Inline RSA keys used by api-gateway SignatureService (single-line PEM, \n escaped)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
RSA_SIGNING_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_BASE64_KEY\n-----END RSA PRIVATE KEY-----
RSA_SIGNING_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_BASE64_KEY\n-----END PUBLIC KEY-----

# ─── Audit Consumer ───────────────────────────────────────────────
AUDIT_CONSUMER_HTTP_PORT=8081
AUDIT_CONSUMER_GROUP_ID=gacp-audit-consumer
AUDIT_CONSUMER_TOPICS=audit.trail.v1,cultivation.plants.v1

# ─── Microservice URLs (used by api-gateway proxy) ───────────────
CULTIVATION_SERVICE_URL=http://localhost:3002
QUALITY_SERVICE_URL=http://localhost:3003
FINANCIAL_SERVICE_URL=http://localhost:3004
WORKFORCE_SERVICE_URL=http://localhost:3005
ANALYTICS_SERVICE_URL=http://localhost:3006

# ─── Dev Tools ────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@gacp-erp.example.com
PGADMIN_PASSWORD=pgadmin_dev_2026
GRAFANA_PORT=3010

# ─── Logging / Loki ───────────────────────────────────────────────
# Set LOKI_URL to enable pino-loki transport (unset disables Loki push)
LOKI_URL=http://loki:3100
LOKI_PORT=3100

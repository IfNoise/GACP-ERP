{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@gacp-erp/shared-schemas": ["libs/shared/schemas/src/index.ts"],
      "@gacp-erp/shared-schemas/*": ["libs/shared/schemas/src/*"],
      "@gacp-erp/shared-contracts": ["libs/shared/contracts/src/index.ts"],
      "@gacp-erp/shared-contracts/*": ["libs/shared/contracts/src/*"],
      "@gacp-erp/shared-events": ["libs/shared/events/src/index.ts"],
      "@gacp-erp/shared-events/*": ["libs/shared/events/src/*"],
      "@gacp-erp/shared-database": ["libs/shared/database/src/index.ts"],
      "@gacp-erp/shared-database/*": ["libs/shared/database/src/*"],
      "@gacp-erp/shared-config": ["libs/shared/config/src/index.ts"],
      "@gacp-erp/shared-config/*": ["libs/shared/config/src/*"],
      "@gacp-erp/shared-keycloak": ["libs/shared/keycloak/src/index.ts"],
      "@gacp-erp/shared-keycloak/*": ["libs/shared/keycloak/src/*"],
      "@gacp-erp/shared-zitadel": ["libs/shared/zitadel/src/index.ts"],
      "@gacp-erp/shared-zitadel/*": ["libs/shared/zitadel/src/*"],
      "@gacp-erp/ui-components": ["libs/ui-components/src/index.ts"],
      "@gacp-erp/ui-components/*": ["libs/ui-components/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", ".nx"]
}

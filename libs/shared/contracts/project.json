{
  "name": "shared-contracts",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "libs/shared/contracts",
  "sourceRoot": "libs/shared/contracts/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project libs/shared/contracts/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared/contracts/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/contracts"],
      "options": {
        "jestConfig": "libs/shared/contracts/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["type:utility", "scope:shared", "domain:contracts"]
}

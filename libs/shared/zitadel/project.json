{
  "name": "shared-zitadel",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "libs/shared/zitadel",
  "sourceRoot": "libs/shared/zitadel/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project libs/shared/zitadel/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared/zitadel/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/zitadel"],
      "options": {
        "jestConfig": "libs/shared/zitadel/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["type:utility", "scope:shared", "domain:auth"]
}

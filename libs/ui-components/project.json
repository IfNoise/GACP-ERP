{
  "name": "ui-components",
  "projectType": "library",
  "sourceRoot": "libs/ui-components/src",
  "prefix": "gacp-erp",
  "tags": ["type:ui", "scope:shared", "framework:react"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project libs/ui-components/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/ui-components/**/*.{ts,tsx}"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/ui-components/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
